{
  "$schema": "https://developer.microsoft.com/json-schemas/api-extractor/v7/api-extractor.schema.json",
  "mainEntryPointFilePath": "./dist/index.d.ts",
  "compiler": { "tsconfigFilePath": "./tsconfig.json" },
  "dtsRollup": { "enabled": true, "untrimmedFilePath": "./dist/qnce-engine.d.ts" },
  "docModel": { "enabled": true, "apiJsonFilePath": "./temp/qnce-engine.api.json" },
  "apiReport": { "enabled": true, "reportFolder": "./etc", "reportFileName": "qnce-engine.api.md", "reportTempFolder": "./temp" },
  "messages": {
  "extractorMessageReporting": { "ae-missing-release-tag": { "logLevel": "error" } },
    "tsdocMessageReporting": { "tsdoc-undefined-tag": { "logLevel": "none" } }
  }
}
